<Window x:Class="TimeCountdown.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:TimeCountdown.ViewModels"
        mc:Ignorable="d"
        Title="{Binding [Window.Main.Title], Source={StaticResource Loc}}"
        Width="420"
        Height="760"
        MinWidth="360"
        MinHeight="560"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        Closing="Window_OnClosing"
        Activated="Window_OnActivated"
        LocationChanged="Window_OnLocationOrSizeChanged"
        SizeChanged="Window_OnLocationOrSizeChanged">
    <Window.Resources>
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F8FBFF" />
            <Setter Property="Foreground" Value="#285786" />
            <Setter Property="BorderBrush" Value="#D7E8F8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderIconButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>

        <Style x:Key="ArchiveViewButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderIconButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowArchivedOnly}" Value="True">
                    <Setter Property="Background" Value="#DCEBFA" />
                    <Setter Property="BorderBrush" Value="#9BBEDE" />
                    <Setter Property="Foreground" Value="#1E507E" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardActionButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="CardIconButtonStyle" TargetType="Button" BasedOn="{StaticResource CardActionButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>

        <Style x:Key="CardListBoxStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#285786" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EAF4FF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#DDEEFF" />
                                <Setter Property="Foreground" Value="#184B79" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Background" Value="#F3F8FF" />
            <Setter Property="Foreground" Value="#25507E" />
            <Setter Property="BorderBrush" Value="#CFE0F2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource FilterComboBoxItemStyle}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedValue, RelativeSource={RelativeSource Self}}" Value="All">
                    <Setter Property="Background" Value="#F3F8FF" />
                    <Setter Property="BorderBrush" Value="#CFE0F2" />
                    <Setter Property="Foreground" Value="#25507E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedValue, RelativeSource={RelativeSource Self}}" Value="Safe">
                    <Setter Property="Background" Value="#EAF7F0" />
                    <Setter Property="BorderBrush" Value="#BFDCC9" />
                    <Setter Property="Foreground" Value="#1F7F43" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedValue, RelativeSource={RelativeSource Self}}" Value="Soon">
                    <Setter Property="Background" Value="#FFF4DF" />
                    <Setter Property="BorderBrush" Value="#F3D59B" />
                    <Setter Property="Foreground" Value="#8A5A00" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedValue, RelativeSource={RelativeSource Self}}" Value="Today">
                    <Setter Property="Background" Value="#FFE8E0" />
                    <Setter Property="BorderBrush" Value="#F1BDA9" />
                    <Setter Property="Foreground" Value="#9F3A16" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedValue, RelativeSource={RelativeSource Self}}" Value="Overdue">
                    <Setter Property="Background" Value="#FFE7EA" />
                    <Setter Property="BorderBrush" Value="#E9B5BD" />
                    <Setter Property="Foreground" Value="#A22A3A" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FBFF" />
                    <Setter Property="BorderBrush" Value="#BFD7EE" />
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="#FFFFFF" />
                    <Setter Property="BorderBrush" Value="#8FB8E0" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Margin="12"
            Background="#EDF5FC"
            BorderBrush="#FDFEFF"
            BorderThickness="1"
            CornerRadius="28"
            PreviewMouseLeftButtonDown="WindowSurface_OnPreviewMouseLeftButtonDown"
            Opacity="{Binding PanelOpacity}">
        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,18" MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="30"
                               FontWeight="Bold"
                               Foreground="#184B79"
                               Text="{Binding [Main.AppTitle], Source={StaticResource Loc}}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                            Click="AddCountdown_Click"
                            Content="&#xE710;"
                            ToolTip="{Binding [Main.Button.New], Source={StaticResource Loc}}" />
                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                            Click="OpenSettings_Click"
                            Content="&#xE713;"
                            ToolTip="{Binding [Main.Button.Settings], Source={StaticResource Loc}}" />
                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                            Click="HideWindow_Click"
                            Content="&#xE921;"
                            ToolTip="{Binding [Main.Button.Hide], Source={StaticResource Loc}}" />
                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                            Click="ExitWindow_Click"
                            Content="&#xE8BB;"
                            ToolTip="{Binding [Main.Button.Exit], Source={StaticResource Loc}}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Height="42"
                         Padding="14,10"
                         Background="#FAFDFF"
                         BorderBrush="#D9E8F6"
                         BorderThickness="1"
                         Foreground="#1B4369"
                         FontSize="14"
                         ToolTip="{Binding [Main.Search.Tooltip], Source={StaticResource Loc}}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                <Button Grid.Column="1"
                        Margin="10,0,0,0"
                        Style="{StaticResource ArchiveViewButtonStyle}"
                        Click="ToggleArchiveView_Click"
                        Content="{Binding ArchiveViewGlyph}"
                        ToolTip="{Binding ArchiveViewTooltipText}" />
            </Grid>

            <Grid Grid.Row="2">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#7A96B3"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Text="{Binding [Main.Empty], Source={StaticResource Loc}}"
                           Visibility="{Binding HasVisibleItems, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                <ListBox Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource CardListBoxStyle}"
                         ItemsSource="{Binding ItemsView}"
                         ScrollViewer.CanContentScroll="False"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:CountdownItemViewModel}">
                            <Border Padding="16"
                                    Background="#FCFEFF"
                                    BorderBrush="#DCE9F6"
                                    BorderThickness="1"
                                    CornerRadius="22">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Padding="12,4"
                                                Background="{Binding StatusBackground}"
                                                CornerRadius="12"
                                                VerticalAlignment="Center">
                                            <TextBlock Foreground="{Binding StatusForeground}"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center"
                                                       Text="{Binding StatusText}" />
                                        </Border>
                                        <Border Margin="8,0,0,0"
                                                Padding="10,4"
                                                Background="#E5F1FF"
                                                CornerRadius="12"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding IsPinned, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Foreground="#4A82BA"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center"
                                                       Text="{Binding [Main.Card.Pinned], Source={StaticResource Loc}}" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                        <Button Style="{StaticResource CardIconButtonStyle}"
                                                Click="ArchiveCountdown_Click"
                                                Content="&#xE7B8;"
                                                ToolTip="{Binding ArchiveActionTooltip}"
                                                Visibility="{Binding IsArchived, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                        <Button Style="{StaticResource CardIconButtonStyle}"
                                                Click="EditCountdown_Click"
                                                Content="&#xE90F;"
                                                ToolTip="{Binding [Common.Edit], Source={StaticResource Loc}}"
                                                Visibility="{Binding IsArchived, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                        <Button Style="{StaticResource CardIconButtonStyle}"
                                                Click="RestoreCountdown_Click"
                                                Content="&#xE72C;"
                                                ToolTip="{Binding RestoreActionTooltip}"
                                                Visibility="{Binding IsArchived, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Button Style="{StaticResource CardIconButtonStyle}"
                                                Click="DeleteCountdown_Click"
                                                Content="&#xE74D;"
                                                ToolTip="{Binding [Common.Delete], Source={StaticResource Loc}}" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="1"
                                               Margin="0,14,0,0"
                                               Foreground="#163D63"
                                               FontSize="26"
                                               FontWeight="Bold"
                                               Text="{Binding Title}"
                                               TextTrimming="CharacterEllipsis" />

                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="18,10,0,0">
                                        <TextBlock HorizontalAlignment="Right"
                                                   Foreground="{Binding ProgressBrush}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Text="{Binding RemainingPrimary}" />
                                        <TextBlock HorizontalAlignment="Right"
                                                   Foreground="#7690AA"
                                                   FontSize="12"
                                                   Text="{Binding RemainingSecondary}" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="2"
                                               Margin="0,8,0,0"
                                               Foreground="#6382A2"
                                               FontSize="14"
                                               Text="{Binding SubtitleDisplay}" />

                                    <TextBlock Grid.Row="3"
                                               Margin="0,4,0,0"
                                               Foreground="#7390AC"
                                               FontSize="13"
                                               Text="{Binding DeadlineDisplay}" />

                                    <TextBlock Grid.Row="3"
                                               Margin="0,24,0,0"
                                               Foreground="#6E8AA6"
                                               FontSize="12"
                                               Text="{Binding ArchivedAtDisplay}"
                                               Visibility="{Binding IsArchived, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <ItemsControl Grid.Row="4"
                                                  Margin="0,12,0,0"
                                                  ItemsSource="{Binding Tags}"
                                                  Visibility="{Binding HasTags, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,8,8"
                                                        Padding="10,4"
                                                        Background="#EEF6FF"
                                                        CornerRadius="12">
                                                    <TextBlock Foreground="#4A7CAE"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <ProgressBar Grid.Row="5"
                                                 Grid.ColumnSpan="2"
                                                 Height="8"
                                                 Margin="0,16,0,0"
                                                 Background="#DCE9F5"
                                                 Foreground="{Binding ProgressBrush}"
                                                 Maximum="100"
                                                 Visibility="{Binding IsArchived, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                 Value="{Binding ProgressPercent, Mode=OneWay}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <Grid Grid.Row="3" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Foreground="#5F81A2"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Text="{Binding SummaryText}" />
                <TextBlock Grid.Column="1"
                           Foreground="#6E8DAA"
                           FontSize="13"
                           Text="{Binding CurrentTimeDisplay}" />
            </Grid>
        </Grid>
    </Border>
</Window>
