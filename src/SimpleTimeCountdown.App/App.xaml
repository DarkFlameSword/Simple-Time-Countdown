<Application x:Class="TimeCountdown.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:TimeCountdown.Converters"
             xmlns:services="clr-namespace:TimeCountdown.Services"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <x:Static Member="services:LocalizationService.Instance" x:Key="Loc" />
    </Application.Resources>
</Application>
